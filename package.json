{
  "name": "tree-sitter-highlight-web",
  "private": true,
  "description": "Parser-accurate syntax highlighting for the web, powered by tree-sitter WASM grammars",
  "homepage": "https://github.com/simeonoff/tree-sitter-highlight-web#readme",
  "bugs": {
    "url": "https://github.com/simeonoff/tree-sitter-highlight-web/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simeonoff/tree-sitter-highlight-web.git"
  },
  "license": "MIT",
  "author": "Simeon Simeonoff",
  "type": "module",
  "workspaces": [
    "packages/*",
    "internal/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "^25.4.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
