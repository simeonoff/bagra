  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simeonoff/bagra.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "Simeon Simeonoff",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
